            "xlsx": "^0.18.5"
      },
      "devDependencies": {
            "@tailwindcss/postcss": "^4.1.17",
            "@vitejs/plugin-react": "^5.1.0",
            "tailwindcss": "^4.1.17",
            "@types/node": "^20.10.0",
            "@types/react": "^18.3.27",
            "@types/react-dom": "^18.3.7",
            "@vitejs/plugin-react-swc": "^3.10.2",
            "concurrently": "^8.2.2",
            "cross-env": "^7.0.3",
            "electron": "^28.1.0",
            "electron-builder": "^24.9.1",
            "vite": "6.3.5",
            "vitest": "^2.1.0",
            "wait-on": "^7.2.0",
            "patch-package": "^8.0.0"
      },
      "scripts": {
            "postinstall": "patch-package",
            "dev": "vite",
            "dev:fresh": "rm -rf node_modules/.vite && vite",
            "test": "vitest",
            "test:run": "vitest run",
            "build": "vite build",
            "preview": "vite preview",
            "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && cross-env NODE_ENV=development electron .\"",
            "electron:dev:fresh": "node scripts/kill-port-3000.js && rm -rf node_modules/.vite && concurrently \"npm run dev\" \"wait-on http://localhost:3000 && cross-env NODE_ENV=development electron .\"",
            "electron:build": "npm run build && electron-builder",
            "electron:build:mac": "npm run build && electron-builder --mac",
            "electron:build:win": "npm run build && electron-builder --win",
            "electron:build:linux": "npm run build && electron-builder --linux",
            "contract:test": "node scripts/test-tender-contract.mjs",
            "check:events": "node scripts/check-event-literals.mjs",
            "check:editor-keys": "node scripts/check-editor-keyboard-wiring.mjs",
            "check:session-state": "node scripts/check-session-state-wiring.mjs",
            "check:session-flow": "node scripts/check-session-flow-readiness.mjs",
            "check:role-mode-contract": "node scripts/check-role-mode-contract.mjs",
            "check:slash-mode": "node scripts/check-slash-mode-consistency.mjs",
            "check:command-palette": "node scripts/check-command-palette-liveness.mjs",
            "check:task-entry": "node scripts/check-task-entry-consistency.mjs",
            "check:single-agent": "node scripts/check-single-agent-readiness.mjs && node scripts/check-command-palette-liveness.mjs"
      },
      "build": {
            "appId": "com.example.ai-assistant",
            "productName": "AI智能助手",
            "directories": {
                  "output": "release",
                  "buildResources": "src/build"
            },
            "files": [
                  "dist/**/*",
                  "src/electron/**/*",
                  "package.json"
            ],
            "extraMetadata": {
                  "main": "src/electron/main.js"
            },
            "mac": {
                  "category": "public.app-category.productivity",
                  "target": [
                        {
                              "target": "dmg",
                              "arch": [
                                    "x64",
                                    "arm64"
                              ]
                        },
                        {
                              "target": "zip",
                              "arch": [
                                    "x64",
                                    "arm64"
                              ]
                        }
                  ],
                  "icon": "src/build/icon.icns",
                  "darkModeSupport": true,
                  "hardenedRuntime": true,
                  "gatekeeperAssess": false,
                  "entitlements": "src/build/entitlements.mac.plist",
                  "entitlementsInherit": "src/build/entitlements.mac.plist"
            },
            "win": {
                  "target": [
                        {
                              "target": "nsis",
                              "arch": [
                                    "x64",
                                    "ia32"
                              ]
                        },
                        {
                              "target": "portable",
                              "arch": [
                                    "x64"
                              ]
                        }
                  ],
                  "icon": "src/build/icon.ico",
                  "artifactName": "${productName}-Setup-${version}.${ext}"
            },
            "nsis": {
                  "oneClick": false,
                  "allowToChangeInstallationDirectory": true,
                  "perMachine": false,
                  "createDesktopShortcut": true,
                  "createStartMenuShortcut": true,
                  "shortcutName": "AI智能助手"
            },
            "linux": {
                  "target": [
                        "AppImage",
                        "deb",
                        "rpm"
                  ],
                  "category": "Office",
                  "icon": "src/build/icon.png"
            }
      },
      "pnpm": {
            "onlyBuiltDependencies": [
                  "electron",
                  "esbuild",
                  "@swc/core"
            ],
            "overrides": {
                  "pdfjs-dist": "5.4.296"
            }
      }
}
