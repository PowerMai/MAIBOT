# 前端桌面端环境变量示例
# 复制为 .env 或 .env.local 后按需修改

# 后端 API 基地址（与 LangGraph 同机）
VITE_API_BASE_URL=http://localhost:2024
VITE_LANGGRAPH_API_URL=http://localhost:2024

# 内部 API 鉴权（与后端 INTERNAL_API_TOKEN 一致，用于模型/云端端点/配置等写接口）
# 缺省与 backend/.env.example 中 INTERNAL_API_TOKEN 同值即可；未配置时仅本机访问写接口需后端放行
VITE_INTERNAL_API_TOKEN=dev_local_token_2024_ccb_secure
VITE_LOCAL_AGENT_TOKEN=dev_local_token_2024_ccb_secure

# 可选：Agent 流式调试 ingest 端点（如 http://127.0.0.1:7242/ingest/xxx），配置后前端将 run_error/EVENT_LOOP/stream_finally 等事件 POST 到该 URL；未配置则不请求，避免 ERR_CONNECTION_REFUSED
# VITE_AGENT_LOG_INGEST_URL=
