# ============================================================
# MAINBOT Digital Worker - 环境变量配置
# 复制此文件为 .env 并填入实际值
# ============================================================

# ── 模型 API Keys ──
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here

# ── LangSmith（LangGraph 本地服务必需）──
LANGSMITH_API_KEY=lsv2_pt_your_api_key_here
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_PROJECT=ccb-digital-worker

# ── 本地模型配置 ──
# DEFAULT_MODEL=qwen3-30b-a3b
# LM_STUDIO_BASE_URL=http://localhost:1234/v1
# DEFAULT_CONTEXT_LENGTH=65536

# ── LangGraph 服务 ──
# LANGGRAPH_API_URL=http://127.0.0.1:2024

# ── 云端模型代理 ──
# CLOUD_PROXY_BASE_URL=
# CLOUD_PROXY_API_KEY=
# OPENROUTER_API_KEY=

# ── 并发与性能 ──
# MAX_PARALLEL_LLM=1
# MAX_PARALLEL_TOOLS=4
# MAX_PARALLEL_AGENTS=1
# MAX_BUDGET_PER_TASK_USD=1.0

# ── 功能开关 ──
# ENABLE_KNOWLEDGE_RETRIEVER=false
# ENABLE_KNOWLEDGE_GRAPH=false   # 启用 knowledge_graph 工具与 KG 增强检索（expand_query、多跳/推理）
# KG_USE_MULTIHOP_IN_RETRIEVAL=true   # 检索时是否使用多跳路径与规则推理（默认 true）
# KG_MULTIHOP_MAX_DEPTH=2   # 检索时多跳路径最大深度（默认 2）
# KNOWLEDGE_RETRIEVAL_TIMEOUT_SEC=0   # search_knowledge 总耗时上限（秒），0=不启用；可配合反向代理超时使用
# AUTO_BUILD_ONTOLOGY_AFTER_UPLOAD=false   # 上传/导入后是否自动触发本体构建
# ENABLE_SELF_LEARNING=false
# ENABLE_LANGMEM=true
# ENABLE_MCP=false
# REFLECTION_EVERY_N_TOOL_CALLS=5   # 反思中间件：每 N 次工具调用注入一次反思提醒（默认 5）

# ── 路径（通常自动检测，无需手动设置）──
# WORKSPACE_ROOT=
# KB_PATH=
# DATA_PATH=

# ── 调试 ──
# ENABLE_AGENT_DEBUG_LOG=false
# ENABLE_MAIN_GRAPH_DEBUG_LOG=false
# DEBUG=false

# ── 内部 API 鉴权（桌面端模型/配置/云端端点等写接口）──
# 缺省配置：与前端 VITE_INTERNAL_API_TOKEN 或 VITE_LOCAL_AGENT_TOKEN 设为相同值即可。
# 未配置时仅允许本机（127.0.0.1/::1）访问写接口；配置后需在前端 .env 中同步该值。
INTERNAL_API_TOKEN=dev_local_token_2024_ccb_secure

# ── CORS ──
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000
