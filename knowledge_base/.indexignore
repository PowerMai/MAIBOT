# ============================================================
# 知识库索引排除规则
# ============================================================
# 此文件定义哪些目录和文件不应被向量化索引
# 语法：每行一个模式，支持目录名和文件扩展名
# 以 # 开头的行为注释

# ============================================================
# 排除的目录
# ============================================================
# 基础资料目录（包含大量 PDF、图片等非文本文件）
基础资料

# 归档目录
archives
archive

# 图片目录
images
img
assets

# 临时目录
tmp
temp
cache

# ============================================================
# 排除的文件类型
# ============================================================
# 二进制文档
*.pdf
*.doc
*.docx
*.xls
*.xlsx
*.ppt
*.pptx

# 图片文件
*.png
*.jpg
*.jpeg
*.gif
*.bmp
*.svg
*.ico
*.webp

# 视频和音频
*.mp4
*.mp3
*.wav
*.avi
*.mov
*.mkv

# 压缩文件
*.zip
*.rar
*.7z
*.tar
*.gz

# 其他二进制文件
*.exe
*.dll
*.so
*.dylib

# ============================================================
# 系统和开发文件
# ============================================================
node_modules
.git
__pycache__
.venv
venv
.env
*.pyc
*.pyo
.DS_Store
Thumbs.db
