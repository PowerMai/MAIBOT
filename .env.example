# ============================================================
# MAIBOT 生产级配置文件示例
# ============================================================
# 复制此文件为 .env 并根据需要修改
# 所有配置项都有合理的默认值，无需全部配置

# ============================================================
# 模型配置
# ============================================================
# LM Studio 服务地址
LM_STUDIO_URL=http://localhost:1234/v1

# 默认模型（auto 表示自动选择第一个可用模型）
LM_STUDIO_MODEL=auto
# 注意：运行时模型 URL/默认模型/timeout/token 上限以 backend/config/models.json 为主；
# 本文件中的 LM_STUDIO_* 与 LLM_* 主要用于兜底与通用开关，不覆盖 models.json 的显式项。

# ============================================================
# 部署模式
# ============================================================
# local: 本地部署，工具直接执行
# cloud: 云端部署，工具通过 MCP 代理
DEPLOYMENT_MODE=local

# MCP Server URL（云端模式需要）
MCP_SERVER_URL=http://localhost:3000

# ============================================================
# 路径与知识库（可选，有默认值；权威定义见 backend/tools/base/paths.py）
# ============================================================
# KB_PATH=                    # 知识库根目录，默认项目根/knowledge_base
# WORKSPACE_PATH=             # 工作区目录，默认项目根/tmp；其下 uploads/、outputs/、.context/、.memory/
# DATA_PATH=                  # 数据目录（向量索引、SQLite），默认项目根/data
# VECTOR_STORE_PATH=          # 向量存储目录，显式指定时优先
# VECTOR_STORE_IN_KB=false    # true 时向量存于 knowledge_base/.vectorstore，便于自包含
# 资源放置与能力说明：docs/resources-and-capabilities.md

# ============================================================
# Agent 能力开关（可选，与 deep_agent / registry 对齐）
# ============================================================
# ENABLE_KNOWLEDGE_RETRIEVER=false  # 知识库检索 search_knowledge；后端默认 false（需要时再开启）
# ENABLE_KNOWLEDGE_GRAPH=false      # 知识图谱 query_kg/extract_entities；后端默认 false
# ENABLE_SELF_LEARNING=true         # 自我学习，后端默认 true；详见下方说明
# ENABLE_LANGMEM=true               # langmem 记忆（search_memory/manage_memory），默认 true
#
# --- 为何知识图谱与自我学习默认关闭 ---
# · 默认 false 原因：减少启动与运行开销、避免早期噪声写入、多数场景下不依赖 KG/学习即可完成任务。
# · 开启 ENABLE_KNOWLEDGE_GRAPH 后：Orchestrator 会挂载 query_kg/extract_entities；需配合知识库或学习数据使用，适合「结构化知识沉淀、按领域过滤经验」。
# · 开启 ENABLE_SELF_LEARNING 后：每次任务结束（main_graph 的 deepagent 节点 finally）会调用 learn_from_success 或 learn_from_failure，将成功/失败模式与推理路径写入工作区 .memory/learning/，并可按 skill_profile/workspace_domain 分段；便于后续检索历史经验、导出用于微调。推荐在稳定使用一段时间、确认任务质量后再开启，避免噪声积累。
# · 推荐开启顺序：先 ENABLE_KNOWLEDGE_RETRIEVER（检索）→ 需要时 ENABLE_KNOWLEDGE_GRAPH（图谱）→ 需要时 ENABLE_SELF_LEARNING（任务后学习）。

# ============================================================
# LLM 性能配置
# ============================================================
# 温度（0.0-1.0，越低越确定）
LLM_TEMPERATURE=0.3

# 单次生成长度上限（tokens）- 控制 LLM 单次回复的最大长度
# 注意：这是「输出」上限，不是模型的上下文窗口
# 模型真实上下文长度（用于压缩与输入预算）以 models.json 的 context_length 为准
LLM_MAX_TOKENS=32768        # 默认任务
LLM_MAX_TOKENS_DOC=131072   # 文档处理
LLM_MAX_TOKENS_FAST=8192    # 快速任务

# 超时配置（秒）
LLM_TIMEOUT=600             # 默认超时 10 分钟
LLM_TIMEOUT_DOC=1200        # 文档处理超时 20 分钟

# 并发配置
MAX_PARALLEL_AGENTS=2       # 最大并行代理数
MAX_DELEGATION_ROUNDS=8     # 最大委派轮数
# MODEL_CALL_LIMIT=80        # 成本保护建议值（默认 200，任务很复杂时可保留默认）

# 性能模式: FAST / BALANCED / QUALITY / DOC
PERFORMANCE_MODE=BALANCED

# ============================================================
# 上下文压缩配置
# ============================================================
# 压缩触发阈值（0.0-1.0），当上下文占用达到 context_length 的该比例时触发压缩
# 默认 0.85（85%），更低=更早压缩（响应更快），更高=更晚压缩（保留更多上下文）
# SUMMARIZATION_TRIGGER_RATIO=0.85

# 默认上下文长度（当 models.json 未配置 context_length 时使用）
# DEFAULT_CONTEXT_LENGTH=65536

# ============================================================
# 缓存配置
# ============================================================
# 低内存模式（8GB 及以下机器：一键缩小 SQLite/Agent/LLM 缓存）
# LOW_MEMORY_MODE=true

# ENABLE_LLM_CACHE=true          # LLM 响应缓存（相同输入复用），默认 true
# LLM 响应缓存大小（条数）；LOW_MEMORY_MODE 时默认 200
LLM_CACHE_MAX_SIZE=1000

# Agent 实例缓存大小；LOW_MEMORY_MODE 时默认 2
AGENT_CACHE_MAX_SIZE=5

# 启动时是否预热 Agent（减少首请求延迟，默认 false）
# AGENT_WARMUP_ON_STARTUP=false

# ============================================================
# 存储清理配置（生产级关键配置）
# ============================================================
# SQLite 检查点保留天数
CHECKPOINT_TTL_DAYS=7

# Store 数据保留天数
STORE_TTL_DAYS=30

# Pickle 缓存保留天数（langgraph dev 模式）
PICKLE_CACHE_TTL_DAYS=3

# Pickle 文件大小限制（MB）
PICKLE_STORE_MAX_SIZE_MB=500
PICKLE_CHECKPOINT_MAX_SIZE_MB=200

# ============================================================
# 定期清理配置
# ============================================================
# 清理任务间隔（秒）
CLEANUP_INTERVAL_SECONDS=3600   # 默认 1 小时

# 启动时是否执行清理
CLEANUP_ON_STARTUP=true

# ============================================================
# HTTP 连接池配置
# ============================================================
HTTP_CONNECT_TIMEOUT=10.0       # 连接超时（秒）
HTTP_READ_TIMEOUT=300.0         # 读取超时（秒）
HTTP_WRITE_TIMEOUT=30.0         # 写入超时（秒）
HTTP_POOL_TIMEOUT=10.0          # 连接池超时（秒）
HTTP_MAX_KEEPALIVE=10           # 保持连接数
HTTP_MAX_CONNECTIONS=20         # 最大连接数
HTTP_KEEPALIVE_EXPIRY=30.0      # 保持连接时间（秒）

# ============================================================
# SQLite 性能配置（LOW_MEMORY_MODE 时默认 8MB cache / 8MB mmap）
# ============================================================
SQLITE_CACHE_SIZE_KB=64000      # 缓存大小（KB），64MB
# SQLITE_MMAP_SIZE_MB=64        # 内存映射大小（MB）
SQLITE_TIMEOUT=30.0             # 连接超时（秒）

# ============================================================
# Embedding 配置
# ============================================================
# EMBEDDING_MODEL=             # 嵌入模型名，默认 text-embedding-qwen3-embedding-0.6b
# EMBEDDING_BASE_URL=          # 嵌入服务地址，默认同 LM_STUDIO_URL
EMBEDDING_CHUNK_SIZE=1000       # 批量处理大小
EMBEDDING_MAX_RETRIES=2         # 重试次数
EMBEDDING_TIMEOUT=60.0          # 请求超时（秒）

# ============================================================
# 工具输出限制（上下文优化）
# ============================================================
# read_file 输出最大字符数，超过时截断并提示
# 默认 100000 字符（约 25K-50K tokens），避免超长文件占满上下文
# READ_FILE_MAX_CHARS=100000

# ============================================================
# 知识库索引（可选，与 storage_manager / embedding_tools 对齐）
# ============================================================
# MAX_FILE_SIZE_KB=5000         # 单文件最大 KB，默认 5000
# KB_FILE_EXTENSIONS=.md,.txt,.pdf,.docx,.xlsx
# INDEX_BATCH_SIZE=50          # add_documents 分批大小
# ALLOWED_EXTENSIONS=           # 同 KB_FILE_EXTENSIONS，与 storage 对齐
# EXCLUDED_PATTERNS=            # 排除目录/文件名片段，逗号分隔

# ============================================================
# Rerank 配置（可选，LM Studio / 独立 rerank 服务）
# ============================================================
# RERANK_ENABLED=true           # 启用检索后精排
# RERANK_BASE_URL=http://localhost:1234/v1   # 默认同 EMBEDDING_BASE_URL
# RERANK_MODEL=                 # 若服务需指定模型名
# RERANK_TOP_N=12               # 精排返回条数
# RERANK_TIMEOUT=30             # Rerank 请求超时（秒）
# RERANK_DEBUG=false            # 调试时打印回退日志

# ============================================================
# 模型配置说明（重要）
# ============================================================
# 模型列表与详细配置在 backend/config/models.json 中定义，包括：
# - context_length: 模型真实上下文窗口（如 65536、131072），用于压缩触发判断
# - max_tokens_*: 各 Agent 类型的生成长度上限
# - temperature, top_p, top_k 等采样参数
#
# 上下文预算 vs 生成长度：
# - context_length（models.json）= 输入 + 输出的总预算，决定何时触发上下文压缩
# - LLM_MAX_TOKENS（本文件）= 单次生成的输出上限，不影响压缩判断
#
# 若模型支持 128K 上下文，建议在 models.json 设置 context_length: 131072

# ============================================================
# LangGraph Server 配置
# ============================================================
LANGGRAPH_HOST=0.0.0.0
LANGGRAPH_PORT=2024
LANGGRAPH_WORKERS=1

# TTL 配置（秒）- 用于 langgraph.json
CHECKPOINT_TTL_SECONDS=604800   # 7 天
STORE_TTL_SECONDS=2592000       # 30 天
CLEANUP_INTERVAL_MINUTES=60     # 1 小时

# 任务看板巡检（默认关闭）：TASK_WATCHER_ENABLED=true 时后台扫描 available 任务并竞标
# 无任务时轮询间隔自动退避（30s -> 300s），减少空闲 CPU/API 消耗
# TASK_WATCHER_ENABLED=false
# TASK_WATCHER_ROLE_ID=           # 不填则使用第一个角色
# TASK_WATCHER_INTERVAL=30        # 有任务时的基础间隔（秒）

# ============================================================
# 外部 API（可选，用于高质量搜索与 Skills 市场）
# ============================================================
# Tavily 搜索：https://tavily.com 获取 API Key，配置后注册 tavily_search 工具
# TAVILY_API_KEY=
# SkillsMP 市场：https://skillsmp.com 登录后获取 API Key，知识管理师可调用 SkillsMP API
# SKILLSMP_API_KEY=

# ============================================================
# 工作场景（Skill Profile，可选）
# ============================================================
# 前端选择工作场景后通过 configurable 传递；本地调试可在此指定默认场景
# 可选值: office | report | research | bidding | contract | full
# SKILL_PROFILE=office

# ============================================================
# 调试配置
# ============================================================
DEBUG=false
